{
  "name": "ccraft-studio",
  "version": "0.4.0-alpha",
  "description": "An app for creating apps or to code easily for Minecraft ComputerCraft Mod",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build:main && npm run build:preload && concurrently -n vite,tsc,electron \"vite\" \"electron . --dev\"",
    "dev:vite": "vite",
    "dev:electron": "npm run build:main && npm run build:preload && electron . --dev",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "package": "npm run build && electron-builder",
    "package:linux": "npm run build && electron-builder --linux AppImage",
    "package:linux:appimage": "npm run build && electron-builder --linux AppImage",
    "package:linux:deb-rpm": "npm run build && electron-builder --linux deb rpm",
    "package:linux:all": "npm run build && electron-builder --linux deb rpm AppImage",
    "typecheck": "tsc --noEmit"
  },
  "author": "Mohamed Mahmodi",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@blockly/field-colour": "^6.0.11",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mit-app-inventor/blockly-block-lexical-variables": "^11.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "blockly": "^12.4.1",
    "nanoid": "^5.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^8.0.5",
    "ws": "^8.20.0",
    "zustand": "^4.5.0"
  },
  "overrides": {
    "@mit-app-inventor/blockly-block-lexical-variables": {
      "blockly": "^12.4.1"
    }
  }
}
